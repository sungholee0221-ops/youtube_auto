# Supabase
SUPABASE_URL=https://dlqnzsvgxhqbqsurcvue.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Cloud TTS
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_TTS_API_KEY=your_google_tts_api_key_here


# Hugging Face
HF_API_TOKEN=your_huggingface_token_here

# Pexels API (무료 - https://www.pexels.com/api/ 에서 발급)
PEXELS_API_KEY=your_pexels_api_key_here

# FFmpeg 경로
FFMPEG_PATH=/usr/local/bin/ffmpeg

# 출력 경로
OUTPUT_DIR_RAIN=/Users/sungho/.n8n-files/비소리채널
OUTPUT_DIR_DINO=/Users/sungho/.n8n-files/공룡채널
OUTPUT_DIR_HISTORY=/Users/sungho/.n8n-files/역사채널

# 배경음악 (채널3용)
BGM_PATH=/path/to/piano_bgm.mp3

# YouTube OAuth (업로드 자동화 시 사용 - Supabase api_keys에도 저장됨)
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
